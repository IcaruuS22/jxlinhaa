# Database Configuration
# Local: Leave blank to use SQLite (database.sqlite)
# Production (Supabase): postgres://postgres.[USER]:[PASSWORD]@[HOST]:5432/postgres
DATABASE_URL=
DATABASE_NAME=database.sqlite

# Content Delivery
DELIVERY_LINK_DEFAULT=https://www.example.com/seu-conteudo

# ===========================================
# INSTRUÇÕES DE CONFIGURAÇÃO
# ===========================================

# 1. JWT_SECRET: Gere uma chave segura de pelo menos 32 caracteres
#    Exemplo: openssl rand -base64 32

# 2. SUPABASE_SERVICE_ROLE_KEY: Encontre no painel do Supabase
#    Dashboard > Settings > API > service_role key

# 3. ALLOWED_ORIGINS: Domínios que podem acessar a API
#    Adicione outros domínios se necessário

# ===========================================
# COMO USAR
# ===========================================

# 1. Copie este arquivo: cp env.example .env.local
# 2. Configure as variáveis acima
# 3. No Vercel, adicione essas variáveis em:
#    Dashboard > Project > Settings > Environment Variables


